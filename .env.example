# ──────────────────────────────────────────────────────────────────────────
# Qvik Map — environment template
#
# HOW TO USE:
#   1. Copy this file to ".env"  ->   cp .env.example .env
#   2. Fill in REAL values in ".env" (especially DB_PASSWORD).
#   3. ".env" is gitignored and must NEVER be committed.
#
# This file (.env.example) is committed on purpose: it documents WHICH
# variables exist, but contains only placeholder values.
# ──────────────────────────────────────────────────────────────────────────

# --- Database ---
# Used by the postgres container AND read by the Spring Boot backend.
DB_PASSWORD=changeme_use_a_long_random_value

# Connection string the backend uses to reach the DB.
# Local (running backend directly):   jdbc:postgresql://localhost:5432/qvikmap
# In docker-compose (service name):   jdbc:postgresql://db:5432/qvikmap
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/qvikmap

# --- Public site ---
# The domain Caddy will serve and fetch HTTPS certificates for.
# For local testing you can use "localhost".
SITE_DOMAIN=yourdomain.hu

# --- (Later) external services — leave blank until needed ---
# Geocoding (self-hosted Nominatim base URL, or a provider key)
NOMINATIM_BASE_URL=
# Ad provider / analytics keys go here when you add them
